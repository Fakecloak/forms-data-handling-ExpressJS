<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title%></title>
</head>
<body>
    <h1><%= title %></h1>

    <p>Results for "<%= search_query %>"  </p>

    <% if (users.length === 0){ %>
        <p> No users found.</p>
    <% } else { %>
        <ul>
            <% users.forEach(user => { %>
                <li>
                    <%= user.firstName%>
                    <%= user.lastName%>
                    <%= user.email%>
                    <%= user.age%>
                    <%= user.bio%> 
                </li>
                <% });%>
        </ul>
       <% } %>

    <a href="/">Back to Home</a>
</body>
</html>